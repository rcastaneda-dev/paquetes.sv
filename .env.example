# ============================================================================
# Next.js app (frontend + API routes)
# ============================================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: enable debug buttons on the home page (shows /api/reports/debug-random actions)
NEXT_PUBLIC_ENABLE_DEBUG_BUTTONS=false

# Optional: worker auth secrets (used by /api/worker/*)
# If set, callers must send: Authorization: Bearer <secret>
SUPABASE_FUNCTION_SECRET=change-me
CRON_SECRET=change-me

# Optional: worker tuning (used by /api/worker/process-tasks and /api/worker/process-category-tasks)
WORKER_BATCH_SIZE=25
WORKER_CONCURRENCY=3
WORKER_MAX_RUNTIME=9000

# Optional: stale task requeue behavior (used by /api/worker/process-tasks)
WORKER_STALE_TASK_SECONDS=900
WORKER_STALE_TASK_LIMIT=5000

# ============================================================================
# Standalone ZIP worker (worker/zip-worker)
# ============================================================================

# Required by ZIP worker:
# - NEXT_PUBLIC_SUPABASE_URL
# - SUPABASE_SERVICE_ROLE_KEY

# Optional: tune ZIP worker performance
POLL_INTERVAL_MS=5000
DOWNLOAD_BATCH_SIZE=50
COMPRESSION_LEVEL=6

# ============================================================================
# Supabase Edge Function (supabase/functions/report-worker)
# ============================================================================

# Optional: shared secret for scheduled invocations (sent as x-worker-secret header)
# Tip: set this equal to SUPABASE_FUNCTION_SECRET so the Edge Function can call the Next.js worker.
FUNCTION_SECRET=change-me

# Required if using the Edge Function to trigger the Next.js worker
NEXTJS_URL=http://localhost:3000
